# MongoDB connection (local default)
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DATABASE=crime_db
MONGODB_COLLECTION=crime_data

# Example Atlas URI format (do not commit real credentials):
# MONGODB_URI=mongodb+srv://crimeadmin:<password>@crime-cluster.abcd123.mongodb.net/?retryWrites=true&w=majority

# Optional Spark MongoDB read URI
# SPARK_MONGO_READ_URI=mongodb+srv://crimeadmin:<password>@crime-cluster.abcd123.mongodb.net/crime_db.crime_data
